<Page x:Class="ForbiddenBookshop.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ForbiddenBookshop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="#2F2F2F" CornerRadius="15" Padding="40" BorderBrush="#800000" BorderThickness="2">
            <StackPanel Width="300">
                <TextBlock Text="Вход в запретный магазин" FontSize="24" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="Логин" Margin="0,0,0,5"/>
                <TextBox x:Name="tbLogin" Margin="0,0,0,15" Height="35"/>
                <TextBlock Text="Пароль" Margin="0,0,0,5"/>
                <PasswordBox x:Name="pbPassword" Margin="0,0,0,15" Height="35"/>
                <Button Content="Войти" Click="BtnLogin_Click" Height="40" Margin="0,0,0,10"/>
                <Button Content="Регистрация" Click="BtnReg_Click" Height="40" Background="#2F2F2F" BorderBrush="#800000"/>
                <TextBlock x:Name="tbError" Foreground="#FF6B6B" Margin="0,10" TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
