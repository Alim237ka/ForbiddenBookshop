<Page x:Class="ForbiddenBookshop.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ForbiddenBookshop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage">

    <ScrollViewer>
        <Border Margin="15" Background="#2F2F2F" CornerRadius="15" Padding="20" BorderBrush="#800000" BorderThickness="2">
            <StackPanel>
                <TextBlock Text="Мой профиль" FontSize="28" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,20"/>

                <Border Background="#191919" CornerRadius="10" Padding="20" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Width="100" Height="100" CornerRadius="50" Background="#800000" Margin="0,0,20,0">
                            <Image x:Name="imgAvatar" Width="100" Height="100" Stretch="UniformToFill">
                                <Image.Source>
                                    <BitmapImage UriSource="/Images/iconProfile.png" />
                                </Image.Source>
                            </Image>
                        </Border>
                        <Button Content="Выбрать аватар" Click="BtnSelectAvatar_Click" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Логин:" Margin="0,10,0,0"/>
                <TextBox x:Name="tbLogin" IsReadOnly="True" Margin="0,5,0,15"/>

                <TextBlock Text="Полное имя:"/>
                <TextBox x:Name="tbFullName" Margin="0,5,0,15"/>

                <TextBlock Text="Новый пароль:"/>
                <PasswordBox x:Name="pbPassword" Margin="0,5,0,15"/>

                <TextBlock Text="Уровень безумия:"/>
                <TextBlock x:Name="tbMadnessLevel" Margin="0,5,0,15" FontWeight="Bold" Foreground="#FF6B6B"/>

                <Button Content="Сохранить изменения" Click="BtnSave_Click" Margin="0,20,0,5" Height="40"/>

                <TextBlock Text="📜 Мои заказы" FontWeight="Bold" FontSize="20" Margin="0,20,0,10"/>
                <ListBox x:Name="lvOrders" Height="250">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#800000" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding OrderDate, StringFormat='Дата: dd.MM.yyyy'}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Status, StringFormat='Статус: {0}'}"/>
                                    <TextBlock Text="{Binding TotalAmount, StringFormat='Сумма: {0:C}'}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Page>
