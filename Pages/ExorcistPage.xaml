<Page x:Class="ForbiddenBookshop.Pages.ExorcistPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ForbiddenBookshop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ExorcistPage"
      Loaded="Page_Loaded">

    <TabControl Margin="10" Background="#191919">
        <TabItem Header="📖 Книги с высоким проклятием" Background="#2F2F2F">
            <ListBox x:Name="lvHighCurseBooks">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#800000" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{Binding Author, StringFormat='Автор: {0}'}" FontSize="12"/>
                                <TextBlock Text="{Binding CurseLevel, StringFormat='⚠️ Уровень проклятия: {0}/10 ⚠️'}" Foreground="#FF6B6B"/>
                                <TextBlock Text="{Binding Language, StringFormat='Язык: {0}'}"/>
                                <Button Content="🔮 Снять проклятие" Click="BtnRemoveCurse_Click" Tag="{Binding BookID}" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </TabItem>

        <TabItem Header="👻 Пропавшие читатели" Background="#2F2F2F">
            <ListBox x:Name="lvDisappeared">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#800000" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                            <StackPanel>
                                <TextBlock Foreground="White" Text="{Binding Customer.User.FullName, StringFormat='Читатель: {0}'}" FontWeight="Bold"/>
                                <TextBlock Foreground="White" Text="{Binding Book.Title, StringFormat='Книга: {0}'}"/>
                                <TextBlock Text="{Binding DisappearanceDate, StringFormat='Дата исчезновения: {0:dd.MM.yyyy}'}"/>
                                <TextBlock Text="{Binding Notes}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </TabItem>

        <TabItem Header="📈 Статистика проклятий" Background="#2F2F2F">
            <ScrollViewer>
                <StackPanel Margin="10">
                    <TextBlock Text="Самые опасные книги:" FontWeight="Bold" FontSize="18" Foreground="#800000"/>
                    <ListBox x:Name="lvDangerousBooks" Height="200" Margin="0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#800000" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel Width="300">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14"/>
                                            <TextBlock Text="{Binding Author, StringFormat='Автор: {0}'}" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="{Binding CurseLevel, StringFormat='Проклятие: {0}/10'}" Foreground="#FF6B6B" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Language, StringFormat='Язык: {0}'}" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="Читатели с высоким уровнем безумия:" FontWeight="Bold" FontSize="18" Margin="0,20,0,0" Foreground="#800000"/>
                    <ListBox x:Name="lvMadCustomers" Height="200" Margin="0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#800000" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel Width="250">
                                            <TextBlock Text="{Binding User.FullName}" Foreground="White" FontWeight="Bold" FontSize="14"/>
                                            <TextBlock Foreground="White" Text="{Binding User.Login, StringFormat='Логин: {0}'}" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="{Binding MadnessLevel, StringFormat='🧠 Безумие: {0}/100'}" Foreground="#FF6B6B" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding RegistrationDate, StringFormat='С регистрации: {0:dd.MM.yyyy}'}" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Page>
