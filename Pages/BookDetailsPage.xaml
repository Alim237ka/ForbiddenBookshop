<Page x:Class="ForbiddenBookshop.Pages.BookDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ForbiddenBookshop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BookDetailsPage">

    <ScrollViewer>
        <Border Margin="15" Background="#2F2F2F" CornerRadius="15" Padding="20" BorderBrush="#800000" BorderThickness="2">
            <StackPanel>
                <TextBlock x:Name="tbTitle" FontSize="32" FontWeight="Bold" TextAlignment="Center"/>
                <TextBlock x:Name="tbAuthor" FontSize="20" TextAlignment="Center" Margin="0,5"/>
                <TextBlock x:Name="tbLanguage" FontSize="16" TextAlignment="Center" Margin="0,5"/>
                <TextBlock x:Name="tbCurseLevel" FontSize="18" TextAlignment="Center" Margin="0,5" Foreground="#FF6B6B"/>
                <TextBlock x:Name="tbPrice" FontSize="20" FontWeight="Bold" TextAlignment="Center" Margin="0,10"/>
                <TextBlock x:Name="tbStock" FontSize="14" TextAlignment="Center"/>
                <TextBlock x:Name="tbDescription" FontSize="14" TextAlignment="Center" TextWrapping="Wrap" Margin="0,15"/>

                <TextBlock Text="📜 История заказов этой книги" FontWeight="Bold" FontSize="20" Margin="0,20,0,10"/>
                <ListBox x:Name="lvOrders" Height="200">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#800000" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Order.OrderDate, StringFormat='Дата заказа: dd.MM.yyyy'}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Order.Status, StringFormat='Статус: {0}'}"/>
                                    <TextBlock Text="{Binding Order.TotalAmount, StringFormat='Сумма: {0:C}'}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="👻 Пропавшие читатели после этой книги" FontWeight="Bold" FontSize="20" Margin="0,20,0,10"/>
                <ListBox x:Name="lvDisappeared" Height="150">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#800000" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Customer.User.FullName, StringFormat='Читатель: {0}'}"/>
                                    <TextBlock Text="{Binding DisappearanceDate, StringFormat='Дата исчезновения: dd.MM.yyyy'}"/>
                                    <TextBlock Text="{Binding Notes, StringFormat='Примечание: {0}'}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Page>
