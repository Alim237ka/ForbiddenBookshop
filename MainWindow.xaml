<Window x:Class="ForbiddenBookshop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ForbiddenBookshop"
        mc:Ignorable="d"
        Title="📖 Книжный магазин запрещенных знаний" Height="700" Width="1000"
        Background="#191919">
    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2F2F2F"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="/Fonts/#blondeFraktur"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="BorderBrush" Value="#800000"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="10" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#800000" CornerRadius="0,0,20,20" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Ellipse Width="80" Height="80" Margin="10">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="/Images/icon.png"/>
                    </Ellipse.Fill>
                </Ellipse>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Запретный Книжный Магазин" FontSize="28" FontWeight="Bold" Foreground="#E0E0E0"/>
                    <TextBlock Text="Книги, после прочтения которых вы исчезнете" FontSize="14" Foreground="#C0C0C0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,10,10,0">
                <Button x:Name="btnCatalog" Content="📚 Каталог книг" Style="{StaticResource MenuButtonStyle}" Click="btnCatalog_Click"/>
                <Button x:Name="btnProfile" Content="👤 Мой профиль" Style="{StaticResource MenuButtonStyle}" Click="btnProfile_Click"/>
                <Button x:Name="btnAdmin" Content="⚙️ Админ-панель" Style="{StaticResource MenuButtonStyle}" Click="btnAdmin_Click"/>
                <Button x:Name="btnExorcist" Content="🗿 Библиотекарь-экзорцист" Style="{StaticResource MenuButtonStyle}" Click="btnExorcist_Click"/>
                <Button x:Name="btnExit" Content="🚪 Выход" Style="{StaticResource MenuButtonStyle}" Click="btnExit_Click"/>
            </StackPanel>

            <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Background="#191919"/>
        </Grid>
    </Grid>
</Window>
