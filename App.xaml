<Application x:Class="ForbiddenBookshop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ForbiddenBookshop"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <DropShadowEffect x:Key="ShadowEffect" BlurRadius="8" ShadowDepth="2" Opacity="0.5" Color="Black"/>
        <FontFamily x:Key="GothicFont">pack://application:,,,/Fonts/#blondeFraktur, Segoe UI, Arial</FontFamily>
        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="/Fonts/#blondeFraktur"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="#191919"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>

        <Style TargetType="Page">
            <Setter Property="FontFamily" Value="/Fonts/#blondeFraktur"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="#191919"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#800000"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="/Fonts/#blondeFraktur"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#A00000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="/Fonts/#blondeFraktur"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="/Fonts/#blondeFraktur"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="#2F2F2F"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#800000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="/Fonts/#blondeFraktur"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="#2F2F2F"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#800000"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="/Fonts/#blondeFraktur"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="#2F2F2F"/>
            <Setter Property="BorderBrush" Value="#800000"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="FontFamily" Value="/Fonts/#blondeFraktur"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#2F2F2F"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#800000"/>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="#191919"/>
        </Style>
    </Application.Resources>
</Application>
