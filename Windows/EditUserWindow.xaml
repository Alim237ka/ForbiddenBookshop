<Window x:Class="ForbiddenBookshop.Windows.EditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ForbiddenBookshop.Windows"
        mc:Ignorable="d"
        Title="EditUserWindow" Height="450" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#191919">

    <Border Background="#2F2F2F" CornerRadius="15" Padding="20" BorderBrush="#800000" BorderThickness="2" Margin="10">
        <StackPanel>
            <TextBlock Text="👤 Редактирование пользователя" FontSize="24" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Логин:"/>
            <TextBox x:Name="tbLogin" Margin="0,5,0,15"/>

            <TextBlock Text="Пароль (оставьте пустым, если не менять):"/>
            <PasswordBox x:Name="pbPassword" Margin="0,5,0,15"/>

            <TextBlock Text="Полное имя:"/>
            <TextBox x:Name="tbFullName" Margin="0,5,0,15"/>

            <TextBlock Text="Роль:"/>
            <ComboBox x:Name="cmbRole" Margin="0,5,0,20">
                <ComboBoxItem Content="Администратор" Tag="1"/>
                <ComboBoxItem Content="Клиент" Tag="2"/>
                <ComboBoxItem Content="Библиотекарь-экзорцист" Tag="3"/>
                <ComboBoxItem Content="Хранитель архивов" Tag="4"/>
                <ComboBoxItem Content="Инспектор проклятий" Tag="5"/>
            </ComboBox>

            <Button Content="💾 Сохранить" Click="BtnSave_Click" Height="40" Margin="0,0,0,10"/>
            <Button Content="❌ Отмена" Click="BtnCancel_Click" Height="40" Background="#2F2F2F" BorderBrush="#800000"/>
        </StackPanel>
    </Border>
</Window>
