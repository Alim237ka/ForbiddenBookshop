<Window x:Class="ForbiddenBookshop.Windows.CreateOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ForbiddenBookshop.Windows"
        mc:Ignorable="d"
        Title="CreateOrderWindow" Height="450" Width="800" WindowStartupLocation="CenterOwner"
        Background="#191919">

    <Border Background="#2F2F2F" CornerRadius="15" Padding="20" BorderBrush="#800000" BorderThickness="2" Margin="10">
        <StackPanel>
            <TextBlock Text="📦 Новый заказ" FontSize="24" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Книга:"/>
            <TextBlock x:Name="tbBookTitle" FontWeight="Bold" FontSize="18" Margin="0,5,0,15"/>

            <TextBlock Text="Количество:"/>
            <TextBox x:Name="tbQuantity" Text="1" Margin="0,5,0,15"/>

            <TextBlock Text="Цена за шт.:"/>
            <TextBlock x:Name="tbPrice" Margin="0,5,0,15"/>

            <TextBlock Text="Итого:"/>
            <TextBlock x:Name="tbTotal" FontWeight="Bold" FontSize="18" Foreground="#800000" Margin="0,5,0,20"/>

            <Button Content="✅ Подтвердить заказ" Click="BtnCreate_Click" Height="40" Margin="0,0,0,10"/>
            <Button Content="❌ Отмена" Click="BtnCancel_Click" Height="40" Background="#2F2F2F" BorderBrush="#800000"/>
        </StackPanel>
    </Border>
</Window>
