<Window x:Class="ForbiddenBookshop.Windows.EditBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ForbiddenBookshop.Windows"
        mc:Ignorable="d"
        Title="EditBookWindow" Height="450" Width="800" WindowStartupLocation="CenterOwner"
        Background="#191919">

    <ScrollViewer>
        <Border Background="#2F2F2F" CornerRadius="15" Padding="20" BorderBrush="#800000" BorderThickness="2" Margin="10">
            <StackPanel>
                <TextBlock Text="📚 Редактирование книги" FontSize="24" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Название:"/>
                <TextBox x:Name="tbTitle" Margin="0,5,0,15"/>

                <TextBlock Text="Автор:"/>
                <TextBox x:Name="tbAuthor" Margin="0,5,0,15"/>

                <TextBlock Text="Уровень проклятия (1-10):"/>
                <ComboBox x:Name="cmbCurseLevel" Margin="0,5,0,15">
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="2"/>
                    <ComboBoxItem Content="3"/>
                    <ComboBoxItem Content="4"/>
                    <ComboBoxItem Content="5"/>
                    <ComboBoxItem Content="6"/>
                    <ComboBoxItem Content="7"/>
                    <ComboBoxItem Content="8"/>
                    <ComboBoxItem Content="9"/>
                    <ComboBoxItem Content="10"/>
                </ComboBox>

                <TextBlock Text="Язык:"/>
                <ComboBox x:Name="cmbLanguage" Margin="0,5,0,15" IsEditable="True">
                    <ComboBoxItem Content="Древний"/>
                    <ComboBoxItem Content="Аккадский"/>
                    <ComboBoxItem Content="Руны"/>
                    <ComboBoxItem Content="Латынь"/>
                    <ComboBoxItem Content="Английский"/>
                    <ComboBoxItem Content="Немецкий"/>
                    <ComboBoxItem Content="Французский"/>
                    <ComboBoxItem Content="Русский"/>
                    <ComboBoxItem Content="Испанский"/>
                    <ComboBoxItem Content="Греческий"/>
                    <ComboBoxItem Content="Египетский"/>
                    <ComboBoxItem Content="Арамейский"/>
                    <ComboBoxItem Content="Тибетский"/>
                    <ComboBoxItem Content="Энохиан"/>
                    <ComboBoxItem Content="Изначальный"/>
                </ComboBox>

                <TextBlock Text="Цена:"/>
                <TextBox x:Name="tbPrice" Margin="0,5,0,15"/>

                <TextBlock Text="Количество на складе:"/>
                <TextBox x:Name="tbStock" Margin="0,5,0,15"/>

                <TextBlock Text="Описание:"/>
                <TextBox x:Name="tbDescription" TextWrapping="Wrap" Height="100" Margin="0,5,0,20"/>

                <Button Content="💾 Сохранить" Click="BtnSave_Click" Height="40" Margin="0,0,0,10"/>
                <Button Content="❌ Отмена" Click="BtnCancel_Click" Height="40" Background="#2F2F2F" BorderBrush="#800000"/>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>
